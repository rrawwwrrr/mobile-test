# /etc/default/adbtest
# Конфигурация adbtest — редактировать перед запуском сервиса.
# После изменений: systemctl restart adbtest

# ── Docker-образы ─────────────────────────────────────────────────────────────

# Образ Appium (обязательно)
APPIUM_IMAGE=appium/appium:latest

# Образ с тестами (обязательно для запуска тестов)
# Без этого параметра тесты не запустятся, работает только Appium.
TEST_IMAGE=rrawwwrrr/adbtest-tests:latest

# Автоматически скачивать образы при каждом старте сервиса (1 = да, 0 = нет)
# Отключи если нет доступа к registry: ADBTEST_PULL=0
ADBTEST_PULL=1

# ── APK ───────────────────────────────────────────────────────────────────────

# Путь к APK-файлу на диске
ADBTEST_APK=/var/lib/adbtest/apk/ApiDemos-debug.apk

# URL для автоматической загрузки APK если файл отсутствует.
# Закомментируй если нет интернета — и скопируй APK вручную:
#   cp ApiDemos-debug.apk /var/lib/adbtest/apk/
# ADBTEST_APK_URL=https://github.com/appium/android-apidemos/releases/download/v6.0.6/ApiDemos-debug.apk

# ── Дашборд ───────────────────────────────────────────────────────────────────

# Адрес и порт HTTP-дашборда
ADBTEST_HTTP_ADDR=:9080

# Путь к SQLite базе данных
ADBTEST_DB=/var/lib/adbtest/reports/adbtest.db

# ── Прочее ────────────────────────────────────────────────────────────────────

# Интервал опроса ADB-устройств
ADBTEST_INTERVAL=5s

# Порт ADB-сервера (обычно менять не нужно)
ADB_PORT=5037
