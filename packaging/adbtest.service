[Unit]
Description=ADB Test Runner
Documentation=https://github.com/rrawwwrrr/adbtest
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=simple
WorkingDirectory=/var/lib/adbtest
EnvironmentFile=/etc/default/adbtest
ExecStart=/usr/local/bin/adbtest --watch
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
